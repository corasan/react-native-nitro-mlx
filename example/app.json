{
  "expo": {
    "name": "nitro-mlx-example",
    "slug": "nitro-mlx",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.reactnative.mlx.example",
      "appleTeamId": "M52W2L8ZQV",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app uses the microphone for speech-to-text transcription."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.reactnative.mlx.example"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "26.0",
            "networkInspector": true,
            "useFrameworks": "static"
          }
        }
      ],
      ["react-native-audio-api", { "iosBackgroundMode": "audio" }]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
