{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["mlxreactnative"],
  "ios": {
    "iosModuleName": "MLXReactNative"
  },
  "android": {
    "androidNamespace": ["mlxreactnative"],
    "androidCxxLibName": "MLXReactNative"
  },
  "autolinking": {
    "LLM": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridLLM"
      }
    },
    "ModelManager": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridModelManager"
      }
    },
    "TTS": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridTTS"
      }
    },
    "STT": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridSTT"
      }
    },
    "Embeddings": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridEmbeddings"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
